# ---------------------------------------------------------------------------
# Real-Time Stock Screener - environment variables
# Copy this file to `.env.local` and fill in real values.
#
# IMPORTANT: None of these are prefixed with NEXT_PUBLIC_ on purpose.
# They MUST stay server-side only. Never expose API keys to the browser.
# ---------------------------------------------------------------------------

# Finnhub free-tier API key (server-side only).
# Used for REST quote/profile/metric calls and the upstream WebSocket feed.
# Get one at https://finnhub.io/dashboard
FINNHUB_API_KEY=

# --- AI insight feature -----------------------------------------------------
# Provide a key for at least ONE provider. The LLM adapter auto-selects based
# on which key is present (Gemini preferred when both are set unless
# LLM_PROVIDER overrides).

# Google Gemini key (free tier). Get one at https://aistudio.google.com/apikey
GEMINI_API_KEY=

# OpenAI key (alternative). Get one at https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Optional explicit provider override: `gemini` or `openai`.
# If omitted, the adapter picks whichever key is available.
LLM_PROVIDER=gemini
